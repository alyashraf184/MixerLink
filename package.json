{
  "name": "mixerlink",
  "version": "0.1.0",
  "private": true,
  "description": "Live collaboration for FL Studio sessions.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @mixerlink/server",
    "desktop": "npm run app:dev --workspace @mixerlink/desktop",
    "desktop:dist": "npm run app:dist --workspace @mixerlink/desktop",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
